{
  "description": "Audit dependencies before Codex installs them or edits supported manifests.",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$(git rev-parse --show-toplevel)/.codex/hooks/depcheck-hook.mjs\"",
            "commandWindows": "node .codex\\hooks\\depcheck-hook.mjs",
            "timeout": 30,
            "statusMessage": "Auditing dependency manifest"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$(git rev-parse --show-toplevel)/.codex/hooks/depcheck-post-hook.mjs\"",
            "commandWindows": "node .codex\\hooks\\depcheck-post-hook.mjs",
            "timeout": 30,
            "statusMessage": "Auditing resolved npm dependencies"
          }
        ]
      }
    ]
  }
}
